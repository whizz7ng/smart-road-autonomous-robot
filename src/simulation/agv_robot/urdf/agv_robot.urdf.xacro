<?xml version="1.0"?>
<robot name="agv_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ============================================================
       AGV Robot URDF - Gazebo Harmonic (gz-sim 8.x) / ROS2 Jazzy
       차동구동, φ300mm 2단 플랫폼
  ============================================================ -->

  <!-- ====================== PROPERTIES ======================== -->
  <xacro:property name="platform_radius"    value="0.150"/>
  <xacro:property name="platform_thickness" value="0.005"/>

  <xacro:property name="wheel_radius"  value="0.0325"/>
  <xacro:property name="wheel_width"   value="0.026"/>
  <xacro:property name="wheel_track"   value="0.255"/>

  <!-- 지면 기준 절대 z → base_link 기준 상대 z 로 변환 시 wheel_radius 빼기 -->
  <xacro:property name="lower_plate_z"  value="0.0225"/>  <!-- 0.020 + 0.005/2 -->
  <xacro:property name="upper_plate_z"  value="0.0775"/>  <!-- 0.0225 + 0.050 + 0.005 -->

  <xacro:property name="caster_radius"  value="0.0075"/>
  <xacro:property name="caster_x"       value="0.130"/>

  <xacro:property name="lidar_radius"   value="0.0482"/>
  <xacro:property name="lidar_height"   value="0.0263"/>

  <xacro:property name="camera_x"  value="0.148"/>
  <xacro:property name="camera_z"  value="0.055"/>  <!-- ground 기준 -->


  <!-- ====================== INERTIA MACROS ==================== -->
  <xacro:macro name="inertia_cylinder" params="mass r l">
    <inertial>
      <mass value="${mass}"/>
      <inertia ixx="${mass*(3*r*r+l*l)/12}" ixy="0" ixz="0"
               iyy="${mass*(3*r*r+l*l)/12}" iyz="0"
               izz="${mass*r*r/2}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="inertia_sphere" params="mass r">
    <inertial>
      <mass value="${mass}"/>
      <inertia ixx="${2*mass*r*r/5}" ixy="0" ixz="0"
               iyy="${2*mass*r*r/5}" iyz="0"
               izz="${2*mass*r*r/5}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="inertia_box" params="mass x y z">
    <inertial>
      <mass value="${mass}"/>
      <inertia ixx="${mass*(y*y+z*z)/12}" ixy="0" ixz="0"
               iyy="${mass*(x*x+z*z)/12}" iyz="0"
               izz="${mass*(x*x+y*y)/12}"/>
    </inertial>
  </xacro:macro>

  <!-- ====================== BASE LINKS ======================== -->
  <link name="base_footprint"/>

  <link name="base_link">
    <visual>
      <geometry><box size="0.001 0.001 0.001"/></geometry>
    </visual>
  </link>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child  link="base_link"/>
    <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
  </joint>

  <!-- ====================== LOWER PLATE ======================= -->
  <link name="lower_plate">
    <visual>
      <geometry>
        <cylinder radius="${platform_radius}" length="${platform_thickness}"/>
      </geometry>
      <material name="dark_gray">
        <color rgba="0.3 0.3 0.3 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${platform_radius}" length="${platform_thickness}"/>
      </geometry>
    </collision>
    <xacro:inertia_cylinder mass="0.8" r="${platform_radius}" l="${platform_thickness}"/>
  </link>

  <joint name="lower_plate_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="lower_plate"/>
    <origin xyz="0 0 ${lower_plate_z - wheel_radius}" rpy="0 0 0"/>
  </joint>

  <!-- ====================== UPPER PLATE ======================= -->
  <link name="upper_plate">
    <visual>
      <geometry>
        <cylinder radius="${platform_radius}" length="${platform_thickness}"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${platform_radius}" length="${platform_thickness}"/>
      </geometry>
    </collision>
    <xacro:inertia_cylinder mass="0.6" r="${platform_radius}" l="${platform_thickness}"/>
  </link>

  <joint name="upper_plate_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="upper_plate"/>
    <origin xyz="0 0 ${upper_plate_z - wheel_radius}" rpy="0 0 0"/>
  </joint>

  <!-- ====================== DRIVE WHEELS ====================== -->
  <xacro:macro name="drive_wheel" params="name side">
    <link name="${name}">
      <visual>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="blue">
          <color rgba="0.1 0.4 0.8 1.0"/>
        </material>
      </visual>
      <collision>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
      <xacro:inertia_cylinder mass="0.15" r="${wheel_radius}" l="${wheel_width}"/>
    </link>

    <joint name="${name}_joint" type="continuous">
      <parent link="base_link"/>
      <child  link="${name}"/>
      <origin xyz="0 ${side * wheel_track/2} 0" rpy="${pi/2} 0 0"/>
      <axis xyz="0 0 1"/>
      <dynamics damping="0.1" friction="0.1"/>
    </joint>
  </xacro:macro>

  <xacro:drive_wheel name="left_wheel"  side=" 1"/>
  <xacro:drive_wheel name="right_wheel" side="-1"/>

  <!-- ====================== BALL CASTERS ====================== -->
  <xacro:macro name="ball_caster" params="name cx">
    <link name="${name}_housing">
      <visual>
        <geometry><box size="0.02 0.02 0.01"/></geometry>
        <material name="light_gray"><color rgba="0.7 0.7 0.7 1.0"/></material>
      </visual>
      <xacro:inertia_box mass="0.02" x="0.02" y="0.02" z="0.01"/>
    </link>
    <joint name="${name}_housing_joint" type="fixed">
      <parent link="base_link"/>
      <child  link="${name}_housing"/>
      <origin xyz="${cx} 0 ${-wheel_radius + caster_radius + 0.005}" rpy="0 0 0"/>
    </joint>

    <link name="${name}_ball">
      <visual>
        <geometry><sphere radius="${caster_radius}"/></geometry>
        <material name="light_gray"/>
      </visual>
      <collision>
        <geometry><sphere radius="${caster_radius}"/></geometry>
      </collision>
      <xacro:inertia_sphere mass="0.01" r="${caster_radius}"/>
    </link>
    <joint name="${name}_ball_joint" type="fixed">
      <parent link="${name}_housing"/>
      <child  link="${name}_ball"/>
      <origin xyz="0 0 ${-caster_radius}" rpy="0 0 0"/>
    </joint>
  </xacro:macro>

  <xacro:ball_caster name="front_caster" cx=" ${caster_x}"/>
  <xacro:ball_caster name="rear_caster"  cx="-${caster_x}"/>

  <!-- ========================= LIDAR ========================== -->
  <link name="lidar_link">
    <visual>
      <geometry>
        <cylinder radius="${lidar_radius}" length="${lidar_height}"/>
      </geometry>
      <material name="black"><color rgba="0.1 0.1 0.1 1.0"/></material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${lidar_radius}" length="${lidar_height}"/>
      </geometry>
    </collision>
    <xacro:inertia_cylinder mass="0.17" r="${lidar_radius}" l="${lidar_height}"/>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="upper_plate"/>
    <child  link="lidar_link"/>
    <origin xyz="0 0 ${platform_thickness/2 + lidar_height/2}" rpy="0 0 0"/>
  </joint>

  <!-- ======================== CAMERA ========================== -->
  <link name="camera_link">
    <visual>
      <geometry><box size="0.03 0.03 0.02"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry><box size="0.03 0.03 0.02"/></geometry>
    </collision>
    <xacro:inertia_box mass="0.05" x="0.03" y="0.03" z="0.02"/>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="camera_link"/>
    <origin xyz="${camera_x} 0 ${camera_z - wheel_radius}" rpy="0 0 0"/>
  </joint>

  <!-- camera_optical_frame: ROS 카메라 좌표계 (Z-forward) -->
  <link name="camera_optical_frame"/>
  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child  link="camera_optical_frame"/>
    <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}"/>
  </joint>

  <!-- ========== GAZEBO HARMONIC (gz-sim) 플러그인 ============ -->

  <!-- 차동구동 -->
  <gazebo>
    <plugin filename="gz-sim-diff-drive-system"
            name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>${wheel_track}</wheel_separation>
      <wheel_radius>${wheel_radius}</wheel_radius>
      <max_linear_acceleration>1.0</max_linear_acceleration>
      <max_angular_acceleration>2.0</max_angular_acceleration>
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
    </plugin>
  </gazebo>

  <!-- 볼캐스터 마찰 제거 -->
  <gazebo reference="front_caster_ball">
    <surface>
      <friction>
        <ode><mu>0</mu><mu2>0</mu2></ode>
      </friction>
    </surface>
  </gazebo>
  <gazebo reference="rear_caster_ball">
    <surface>
      <friction>
        <ode><mu>0</mu><mu2>0</mu2></ode>
      </friction>
    </surface>
  </gazebo>

  <!-- 바퀴 마찰 -->
  <gazebo reference="left_wheel">
    <surface>
      <friction>
        <ode><mu>1.0</mu><mu2>0.5</mu2></ode>
      </friction>
    </surface>
  </gazebo>
  <gazebo reference="right_wheel">
    <surface>
      <friction>
        <ode><mu>1.0</mu><mu2>0.5</mu2></ode>
      </friction>
    </surface>
  </gazebo>

  <!-- LiDAR 센서 -->
  <gazebo reference="lidar_link">
    <sensor name="lidar_sensor" type="gpu_lidar">
      <topic>scan</topic>
      <update_rate>10</update_rate>
      <lidar>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.12</min>
          <max>8.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </lidar>
      <always_on>true</always_on>
      <visualize>false</visualize>
    </sensor>
  </gazebo>

  <!-- 카메라 센서 -->
  <gazebo reference="camera_link">
    <sensor name="camera_sensor" type="camera">
      <topic>camera/image_raw</topic>
      <update_rate>30</update_rate>
      <camera>
        <horizontal_fov>1.2217</horizontal_fov>  <!-- 70° HBV-W202012HD -->
        <image>
          <width>1280</width>
          <height>800</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.02</near>
          <far>300</far>
        </clip>
      </camera>
      <always_on>true</always_on>
      <visualize>false</visualize>
    </sensor>
  </gazebo>

</robot>
