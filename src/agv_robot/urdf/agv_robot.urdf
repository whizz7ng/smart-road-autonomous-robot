<robot name="agv_robot">
  <!-- ============================================================
       AGV Robot URDF
       구조: 차동구동 (Differential Drive)
       - 원형 2단 플랫폼 (lower/upper plate, φ300mm)
       - 좌우 구동 바퀴 × 2 (φ65mm, 폭 26mm, track 255mm)
       - 볼 캐스터 × 2 (φ15mm, 전/후)
       - LiDAR: LD14 (상판 상단 장착)
       - USB Camera (전면 하판 장착)
  ============================================================ -->
  <!-- ======================== PROPERTIES ======================== -->
  <!-- 바퀴 중심 간 거리 -->
  <!-- 0.0225 + 0.050 + 0.005 -->
  <!-- ground 기준 5.5cm -->
  <!-- ======================== BASE LINK ======================== -->
  <!-- base_link: 로봇 기준점 (지면 위 바퀴 중심 높이) -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.001 0.001 0.001"/>
      </geometry>
    </visual>
  </link>
  <!-- base_footprint: 지면 투영점 (Nav2 표준) -->
  <link name="base_footprint"/>
  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin rpy="0 0 0" xyz="0 0 0.0325"/>
  </joint>
  <!-- ====================== LOWER PLATE ======================= -->
  <link name="lower_plate">
    <visual>
      <geometry>
        <cylinder length="0.005" radius="0.15"/>
      </geometry>
      <material name="dark_gray">
        <color rgba="0.3 0.3 0.3 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.005" radius="0.15"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.8"/>
      <inertia ixx="0.004501666666666666" ixy="0" ixz="0" iyy="0.004501666666666666" iyz="0" izz="0.009"/>
    </inertial>
  </link>
  <joint name="lower_plate_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lower_plate"/>
    <!-- base_link 기준: 하판 중심 z = lower_plate_z - wheel_radius -->
    <origin rpy="0 0 0" xyz="0 0 -0.010000000000000002"/>
  </joint>
  <!-- ====================== UPPER PLATE ======================= -->
  <link name="upper_plate">
    <visual>
      <geometry>
        <cylinder length="0.005" radius="0.15"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.005" radius="0.15"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.6"/>
      <inertia ixx="0.003376249999999999" ixy="0" ixz="0" iyy="0.003376249999999999" iyz="0" izz="0.00675"/>
    </inertial>
  </link>
  <joint name="upper_plate_joint" type="fixed">
    <parent link="base_link"/>
    <child link="upper_plate"/>
    <origin rpy="0 0 0" xyz="0 0 0.045"/>
  </joint>
  <link name="left_wheel">
    <visual>
      <geometry>
        <cylinder length="0.026" radius="0.0325"/>
      </geometry>
      <material name="blue">
        <color rgba="0.1 0.4 0.8 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.026" radius="0.0325"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.15"/>
      <inertia ixx="4.8059375e-05" ixy="0" ixz="0" iyy="4.8059375e-05" iyz="0" izz="7.921875e-05"/>
    </inertial>
  </link>
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <!-- 바퀴 회전축 = Y축, 좌우 배치 -->
    <origin rpy="1.5707963267948966 0 0" xyz="0 0.1275 0"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>
  <link name="right_wheel">
    <visual>
      <geometry>
        <cylinder length="0.026" radius="0.0325"/>
      </geometry>
      <material name="blue">
        <color rgba="0.1 0.4 0.8 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.026" radius="0.0325"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.15"/>
      <inertia ixx="4.8059375e-05" ixy="0" ixz="0" iyy="4.8059375e-05" iyz="0" izz="7.921875e-05"/>
    </inertial>
  </link>
  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <!-- 바퀴 회전축 = Y축, 좌우 배치 -->
    <origin rpy="1.5707963267948966 0 0" xyz="0 -0.1275 0"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>
  <!-- 캐스터 하우징 (dummy) -->
  <link name="front_caster_housing">
    <visual>
      <geometry>
        <box size="0.02 0.02 0.01"/>
      </geometry>
      <material name="light_gray">
        <color rgba="0.7 0.7 0.7 1.0"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.02"/>
      <inertia ixx="8.333333333333334e-07" ixy="0" ixz="0" iyy="8.333333333333334e-07" iyz="0" izz="1.3333333333333336e-06"/>
    </inertial>
  </link>
  <joint name="front_caster_housing_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_caster_housing"/>
    <origin rpy="0 0 0" xyz="0.13 0 -0.02"/>
  </joint>
  <!-- 볼 -->
  <link name="front_caster_ball">
    <visual>
      <geometry>
        <sphere radius="0.0075"/>
      </geometry>
      <material name="light_gray"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.0075"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="2.2499999999999996e-07" ixy="0" ixz="0" iyy="2.2499999999999996e-07" iyz="0" izz="2.2499999999999996e-07"/>
    </inertial>
  </link>
  <joint name="front_caster_ball_joint" type="fixed">
    <parent link="front_caster_housing"/>
    <child link="front_caster_ball"/>
    <origin rpy="0 0 0" xyz="0 0 -0.0075"/>
  </joint>
  <!-- 캐스터 하우징 (dummy) -->
  <link name="rear_caster_housing">
    <visual>
      <geometry>
        <box size="0.02 0.02 0.01"/>
      </geometry>
      <material name="light_gray">
        <color rgba="0.7 0.7 0.7 1.0"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.02"/>
      <inertia ixx="8.333333333333334e-07" ixy="0" ixz="0" iyy="8.333333333333334e-07" iyz="0" izz="1.3333333333333336e-06"/>
    </inertial>
  </link>
  <joint name="rear_caster_housing_joint" type="fixed">
    <parent link="base_link"/>
    <child link="rear_caster_housing"/>
    <origin rpy="0 0 0" xyz="-0.13 0 -0.02"/>
  </joint>
  <!-- 볼 -->
  <link name="rear_caster_ball">
    <visual>
      <geometry>
        <sphere radius="0.0075"/>
      </geometry>
      <material name="light_gray"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.0075"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="2.2499999999999996e-07" ixy="0" ixz="0" iyy="2.2499999999999996e-07" iyz="0" izz="2.2499999999999996e-07"/>
    </inertial>
  </link>
  <joint name="rear_caster_ball_joint" type="fixed">
    <parent link="rear_caster_housing"/>
    <child link="rear_caster_ball"/>
    <origin rpy="0 0 0" xyz="0 0 -0.0075"/>
  </joint>
  <!-- ========================= LIDAR ========================== -->
  <!-- LD14: 상판 상단 기준으로 장착, 중앙 -->
  <link name="lidar_link">
    <visual>
      <geometry>
        <cylinder length="0.0263" radius="0.0482"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.0263" radius="0.0482"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.17"/>
      <inertia ixx="0.00010853664166666668" ixy="0" ixz="0" iyy="0.00010853664166666668" iyz="0" izz="0.0001974754"/>
    </inertial>
  </link>
  <joint name="lidar_joint" type="fixed">
    <parent link="upper_plate"/>
    <child link="lidar_link"/>
    <!-- 상판 중심 → 상판 상단 = platform_thickness/2 → LiDAR 중심 = + lidar_height/2 -->
    <origin rpy="0 0 0" xyz="0 0 0.01565"/>
  </joint>
  <!-- ======================== CAMERA ========================== -->
  <link name="camera_link">
    <visual>
      <geometry>
        <box size="0.03 0.03 0.02"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.03 0.03 0.02"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="5.416666666666666e-06" ixy="0" ixz="0" iyy="5.416666666666666e-06" iyz="0" izz="7.5e-06"/>
    </inertial>
  </link>
  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin rpy="0 0 0" xyz="0.148 0 0.0225"/>
  </joint>
  <!-- camera_optical_frame: ROS 카메라 좌표계 관례 (Z-forward) -->
  <link name="camera_optical_frame"/>
  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_optical_frame"/>
    <origin rpy="-1.5707963267948966 0 -1.5707963267948966" xyz="0 0 0"/>
  </joint>
  <!-- ===================== GAZEBO PLUGINS ===================== -->
  <!-- 차동구동 플러그인 (ROS2 / Gazebo Classic용) -->
  <gazebo>
    <plugin filename="libgazebo_ros_diff_drive.so" name="differential_drive_controller">
      <ros>
        <namespace>/</namespace>
      </ros>
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.255</wheel_separation>
      <wheel_diameter>0.065</wheel_diameter>
      <max_wheel_torque>5.0</max_wheel_torque>
      <max_wheel_acceleration>1.0</max_wheel_acceleration>
      <command_topic>cmd_vel</command_topic>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>false</publish_wheel_tf>
      <odometry_topic>odom</odometry_topic>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_footprint</robot_base_frame>
    </plugin>
  </gazebo>
  <!-- LiDAR 플러그인 (2D LaserScan) -->
  <gazebo reference="lidar_link">
    <sensor name="lidar_sensor" type="ray">
      <pose>0 0 0 0 0 0</pose>
      <visualize>false</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.12</min>
          <max>8.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </ray>
      <plugin filename="libgazebo_ros_ray_sensor.so" name="lidar_plugin">
        <ros>
          <remapping>~/out:=scan</remapping>
        </ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>lidar_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>
  <!-- 카메라 플러그인 -->
  <gazebo reference="camera_link">
    <sensor name="camera_sensor" type="camera">
      <update_rate>30.0</update_rate>
      <camera name="camera">
        <horizontal_fov>1.2217</horizontal_fov>
        <!-- 70° HBV-W202012HD V33 -->
        <image>
          <width>1280</width>
          <height>800</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.02</near>
          <far>300</far>
        </clip>
      </camera>
      <plugin filename="libgazebo_ros_camera.so" name="camera_plugin">
        <frame_name>camera_optical_frame</frame_name>
      </plugin>
    </sensor>
  </gazebo>
  <!-- 볼캐스터 마찰 제거 -->
  <gazebo reference="front_caster_ball">
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
  </gazebo>
  <gazebo reference="rear_caster_ball">
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
  </gazebo>
  <!-- 바퀴 마찰 설정 -->
  <gazebo reference="left_wheel">
    <mu1>1.0</mu1>
    <mu2>0.5</mu2>
  </gazebo>
  <gazebo reference="right_wheel">
    <mu1>1.0</mu1>
    <mu2>0.5</mu2>
  </gazebo>
</robot>
